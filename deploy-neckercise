#!/bin/bash
set -e

echo "=== Hans Neckercise - Deploy to GitHub + Vercel ==="
echo ""

# Check prerequisites
if ! command -v git &> /dev/null; then echo "ERROR: git not found. Install via: xcode-select --install"; exit 1; fi
if ! command -v gh &> /dev/null; then echo "ERROR: gh not found. Install via: brew install gh"; exit 1; fi
if ! command -v vercel &> /dev/null; then echo "Installing Vercel CLI..."; npm install -g vercel; fi

# Check gh auth
if ! gh auth status &> /dev/null; then
  echo "You need to log in to GitHub CLI first."
  gh auth login
fi

# Setup project
PROJECT_DIR="$HOME/hans-neckercise"
SOURCE_DIR="$HOME/Desktop/Claude/Projects/Hans Neckercise"

echo "Creating project at $PROJECT_DIR..."
mkdir -p "$PROJECT_DIR"

# Copy source files (excluding node_modules, dist folders)
rsync -av --exclude='node_modules' --exclude='dist' --exclude='dist2' --exclude='dist_new' --exclude='.git' --exclude='.vercel' "$SOURCE_DIR/" "$PROJECT_DIR/"

cd "$PROJECT_DIR"

# Install dependencies
echo "Installing dependencies..."
npm install

# Clean old dist and build fresh
echo "Building..."
rm -rf dist
npm run build

# Verify build output
if [ ! -f "dist/index.html" ]; then
  echo "ERROR: Build failed - dist/index.html not found"
  exit 1
fi
echo "Build OK: $(ls dist/assets/*.css 2>/dev/null | head -1) $(ls dist/assets/*.js 2>/dev/null | head -1)"

# Create .gitignore if missing
if [ ! -f ".gitignore" ]; then
cat > .gitignore << 'EOF'
node_modules
dist
.DS_Store
*.local
EOF
fi

# Init git if needed
if [ ! -d ".git" ]; then
  git init
  git branch -M main
fi

git add -A
git commit -m "Update Hans Neckercise" 2>/dev/null || echo "No changes to commit"

# Create GitHub repo (skip if already exists)
if gh repo view hansherrlin-spec/hans-neckercise &> /dev/null; then
  echo "GitHub repo already exists, pushing..."
  git remote add origin https://github.com/hansherrlin-spec/hans-neckercise.git 2>/dev/null || true
  git push -u origin main
else
  echo "Creating GitHub repo..."
  gh repo create hans-neckercise --public --source=. --remote=origin --push
fi

echo ""
echo "GitHub repo: https://github.com/hansherrlin-spec/hans-neckercise"
echo ""

# Deploy to Vercel (framework auto-detected via vercel.json)
echo "Deploying to Vercel..."
vercel --yes --prod

echo ""
echo "=== DONE ==="
echo "Hans Neckercise is now live at https://hans-neckercise.vercel.app"
echo ""
echo "To update after changes, run:"
echo "  cd ~/Desktop/Claude/Projects/Hans\\ Neckercise && bash deploy-neckercise"
